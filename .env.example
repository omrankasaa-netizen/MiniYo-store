# ═══════════════════════════════════════════════════════════════
# MiniYo Store — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# Sensitive values (passwords, secrets) go in Railway env vars ONLY.
# ═══════════════════════════════════════════════════════════════

# ── Kimi OAuth (for admin login) ──
APP_ID=19ea3c1d-70f2-804d-8000-0000b3fca5a0
APP_SECRET=your_app_secret_here

# ── Frontend Kimi Config ──
VITE_APP_ID=19ea3c1d-70f2-804d-8000-0000b3fca5a0
VITE_KIMI_AUTH_URL=https://auth.kimi.com

# ── Database (MySQL) ──
# Railway provides DATABASE_URL automatically when you provision MySQL.
# Format: mysql://username:password@host:port/database
DATABASE_URL=mysql://root:password@host:port/railway

# ── Kimi Platform URLs ──
KIMI_AUTH_URL=https://auth.kimi.com
KIMI_OPEN_URL=https://open.kimi.com

# ── Admin Account ──
OWNER_UNION_ID=d8as01gpe77usiq9k6pg
ADMIN_PASSWORD=your_admin_password_here
ADMIN_EMAIL=admin@miniyo.store

# ── SMTP / Email (GoDaddy Workspace Email) ──
# These are the FALLBACK values. The live values are stored in the
# site_settings DB table and can be edited from the Admin → Settings panel.
# Set SMTP_PASS in Railway environment variables — never in this file.
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=Management@miniyo.store
SMTP_PASS=your_smtp_password_here
SMTP_FROM_NAME=MiniYo Store
SMTP_FROM_EMAIL=Management@miniyo.store

# Notification recipients (comma-separated for multiple)
NOTIFY_ORDERS_TO=Management@miniyo.store,admin@miniyo.store
NOTIFY_CONTACT_TO=Management@miniyo.store

# ── Store Info (overridable from Admin → Settings) ──
STORE_NAME=MiniYo
STORE_URL=https://miniyo.store
STORE_PHONE=+961
STORE_WHATSAPP=+961
STORE_INSTAGRAM=https://instagram.com/miniyo.lb
STORE_FACEBOOK=

# ── App ──
NODE_ENV=production
PORT=3000
