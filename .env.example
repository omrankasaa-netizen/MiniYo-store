# ── App ──────────────────────────────────────────────────────────
APP_ID=your_app_id
APP_SECRET=your_app_secret
APP_URL=https://miniyo.store
NODE_ENV=production
PORT=3000

# ── Database ─────────────────────────────────────────────────────
# MySQL connection string
DATABASE_URL=mysql://user:password@host:3306/miniyo

# ── OAuth (Kimi / WeChat) ────────────────────────────────────────
KIMI_AUTH_URL=https://your-kimi-auth-url
KIMI_OPEN_URL=https://your-kimi-open-url
OWNER_UNION_ID=

# ── Admin ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@miniyo.store
ADMIN_PASSWORD=your_secure_admin_password

# ── CORS ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://miniyo.store,https://www.miniyo.store

# ── SMTP (Email) ─────────────────────────────────────────────────
# Leave blank until you're ready — emails queue automatically and
# send once these are filled in.
#
# For Gmail:    SMTP_HOST=smtp.gmail.com  SMTP_PORT=587
# For Outlook:  SMTP_HOST=smtp.office365.com  SMTP_PORT=587
# For Brevo:    SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587
# For Mailgun:  SMTP_HOST=smtp.mailgun.org  SMTP_PORT=587
#
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Miniyo Store" <hello@miniyo.store>
