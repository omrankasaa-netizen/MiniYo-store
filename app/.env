# =============================================================================
# Miniyo - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# ALL variables marked (Required) must be set before deployment.
# Variables marked (Build-time) must be available during `npm run build`.
# =============================================================================

# ── NODE_ENV ──
# Set automatically by the platform. Do NOT set manually unless running locally.
# NODE_ENV=production

# ── Server Port ──
# The port your app listens on. GoDaddy/Railway will override this.
# PORT=3000

# =============================================================================
# BACKEND - Runtime Variables (Required in production)
# =============================================================================

# Your Kimi Application ID (found in Kimi Developer Console)
APP_ID=19ea3c1d-70f2-804d-8000-0000b3fca5a0

# Your Kimi Application Secret (found in Kimi Developer Console)
APP_SECRET=mTApcfdw9GRVYUdAQjIHJEzM0BCM1rif

# MySQL Database connection URL
# Format: mysql://root:WUBAEWNXpRMbZOZTgsEmZJkqDbBQNFkN@mysql.railway.internal:3306/railway
# GoDaddy:mysql://root:WUBAEWNXpRMbZOZTgsEmZJkqDbBQNFkN@mysql.railway.internal:3306/railway

# Kimi Authentication URL (usually fixed)
KIMI_AUTH_URL=https://auth.kimi.com

# Kimi Open Platform URL (usually fixed)
KIMI_OPEN_URL=https://open.kimi.com

# =============================================================================
# BACKEND - Optional Variables
# =============================================================================

# Your Kimi Union ID (for owner/admin access via OAuth)
OWNER_UNION_ID=d8as01gpe77usiq9k6pg

# Admin password for local login (non-OAuth)
ADMIN_PASSWORD=MiniYostore!b

# Admin email address
ADMIN_EMAIL=admin@miniyo.store

# Allowed CORS origins (comma-separated). Leave empty to allow all.
# Example: ALLOWED_ORIGINS=https://miniyo.store,https://www.miniyo.store
ALLOWED_ORIGINS=

# =============================================================================
# FRONTEND - Build-Time Variables (Must be available during `npm run build`)
# =============================================================================
# These get embedded into the frontend bundle at build time.
# They must be prefixed with VITE_ for Vite to expose them to the browser.

# Same as APP_ID above - needed by the login page
VITE_APP_ID=19ea3c1d-70f2-804d-8000-0000b3fca5a0

# Same as KIMI_AUTH_URL above - needed by the login page
VITE_KIMI_AUTH_URL=https://auth.kimi.com
